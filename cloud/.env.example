# Houston Cloud — control plane + web client.
# Copy to .env.local and fill in. NEVER commit real values.

# --- Supabase (public, safe in browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Newer publishable key (sb_publishable_...). Legacy anon JWT (eyJ...) also
# accepted via NEXT_PUBLIC_SUPABASE_ANON_KEY if you prefer.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- Server-only secrets ---
# Service-role key: box store writes + stamped into each box's cloud event sink.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Stamped into each provisioned box for the in-box agent CLIs.
ANTHROPIC_API_KEY=sk-ant-...

# --- Sandbox backend ---
# "upstash" (default) or "mock". Use "mock" for an offline demo (in-memory
# store, fake boxes) — then the secrets above can be dummy values.
SANDBOX_PROVIDER=upstash
# Upstash Box auth — read by the @upstash/box SDK.
UPSTASH_BOX_API_KEY=box_...
